[General]
title = 桃源谷首页净化
desc = 去除 CPS 推广入口 (微信/支付宝/乐园)
author = lhcin
version = 1.0.0

[MITM]
hostname = lxj.taoyuangu.com

[Script]
# 核心脚本配置
TyCleaner = type=http-response, pattern=^https:\/\/lxj\.taoyuangu\.com, requires-body=1, max-size=0, script-path=https://raw.githubusercontent.com/lhcin/Rules/main/Loon/TyCleaner.js, timeout=10
